{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Magic Bill",
  "version": "0.1.6",
  "identifier": "com.magicbill.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Magic Bill",
        "width": 800,
        "height": 600,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "publisher": "magicbill",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/magicbill-dev/magic-bill/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMxM0Y5MUI4RjM0NkExQTgKUldTb29VYnp1SkUvTWZNWFVLbW5FNFZNeVFTeXcwb0U0Tm5FMFRpdFhyVFlyb2taQzFBQSt5Mm4K"
    }
  }
}